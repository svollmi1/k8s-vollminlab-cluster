{
  "yaml.schemas": {
    "kubernetes://schema/kyverno.io/v1@clusterpolicy": [
      "clusters/**/policies/*.yaml"
    ],
    "kubernetes://schema/kyverno.io/v2@policyexception": [
      "clusters/**/policies/flux-exception.yaml"
    ],
    "https://json.schemastore.org/kustomization.json": [
      "**/kustomization.yaml"
    ],
    "./.vscode/empty-schema.json": [
      "**/patch.yaml",
      "**/*.patch.yaml"
    ]
  },
  "files.associations": {
    "*.patch.yaml": "yaml",
    "*patch.yaml": "yaml",
    "patch.yaml": "yaml"
  },
  "files.eol": "\n"
}
